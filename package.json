{
  "name": "hammidu-resume",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/xebec-render build",
    "test": "bun test",
    "roundtrip": "bun test-roundtrip.ts",
    "xebec:example": "bun run --cwd packages/xebec-render example.ts",
    "xebec:test": "bun run --cwd packages/xebec-render test-validator.ts",
    "flouka:web": "bun run --cwd packages/flouka-studio --watch web-server.ts",
    "flouka:example": "bun run --cwd packages/flouka-studio example.ts",
    "validator:example": "bun run --cwd packages/validator example.ts",
    "validator:validate": "bun run --cwd packages/validator cli.ts",
    "extractor:example": "bun run --cwd packages/extractor example.ts",
    "agent:cli": "bun run --cwd packages/agent src/cli.ts",
    "agent:example": "bun run --cwd packages/agent src/example.ts",
    "agent:run": "bun run --cwd packages/agent run.ts",
    "web": "bun run flouka:web",
    "example": "bun run xebec:example",
    "validate": "bun run validator:example",
    "extract": "bun run extractor:example"
  },
  "devDependencies": {
    "@jsonresume/schema": "^1.2.1",
    "@types/bun": "latest",
    "bun-types": "latest"
  }
}
